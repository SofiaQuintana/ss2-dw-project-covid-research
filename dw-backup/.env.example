# ─── Postgres (destino del backup) ─────────────────────────────
# PG_* los usa el script load-postgresql.py
PG_USER=dw_backup
PG_PASSWORD=cambia_esto_por_un_secreto_fuerte
PG_DB=dw_backup
PG_HOST=postgres          # nombre del servicio en docker-compose
PG_PORT=5432
# POSTGRES_* los usa la imagen Docker de Postgres (deben coincidir con los de arriba)
POSTGRES_USER=dw_backup
POSTGRES_PASSWORD=cambia_esto_por_un_secreto_fuerte
POSTGRES_DB=dw_backup

# ─── Databricks (origen) ───────────────────────────────────────
# Host SIN https:// final ni slash. Ej: adb-1234567890.11.azuredatabricks.net
DATABRICKS_SERVER_HOSTNAME=adb-xxxxxxxxxxxx.xx.azuredatabricks.net
# SQL Warehouse -> Connection details -> HTTP path
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/xxxxxxxxxxxxxxxx
# Personal Access Token (dapi...). NO lo subas a git.
DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── ETL ───────────────────────────────────────────────────────
BATCH_SIZE=100000         # filas por lote en el COPY
